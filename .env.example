# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: fix redirect uri (recommended when using ngrok/custom domain)
GOOGLE_REDIRECT_URI=

# Admin master email (default: shindong0514@gmail.com)
MASTER_EMAIL=shindong0514@gmail.com

# Storage backend: "json" (default) or "firestore"
STORE=json

# Firebase Web SDK (public config)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
# Optional:
FIREBASE_MEASUREMENT_ID=
FIREBASE_STORAGE_BUCKET=

# Firebase Admin credentials (choose one)
# 1) Path to service account json:
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\serviceAccountKey.json
#
# 2) Inline JSON (stringified):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Server
# PORT=3000
# FFMPEG_PATH=ffmpeg
